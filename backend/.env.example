# Get a FREE key at console.groq.com (no credit card needed)
GROQ_API_KEY=your-groq-key-here

# LLM (free via Groq)
LLM_MODEL=llama3-8b-8192
LLM_TEMPERATURE=0.1

# Embeddings run locally for FREE (no API key needed)
# Model downloads ~130MB on first run, cached after that

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# Storage
FAISS_INDEX_PATH=./data/faiss_index
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50
